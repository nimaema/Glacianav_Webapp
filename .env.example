# Server .env for docker-compose.yml — copy to .env next to this file on
# the deployment host and fill in. This is DIFFERENT from .env.local.example
# (that one's for local `npm run dev`); this one also carries the container-
# only S3/MinIO and Cloudflare Tunnel settings docker-compose.yml needs.

# ── Supabase (same values as local .env.local) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Transaction pooler (port 6543) — Settings → Database → Connection string
DATABASE_URL=

# ── Auth gating ──
# true = require sign-in (see middleware.ts). Only set this after a real
# sign-in against THIS domain's Azure redirect URI has been verified.
AUTH_REQUIRED=true

# ── MinIO (local audio storage — private bucket, proxied via API route) ──
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me-strong-password
S3_BUCKET=audio
S3_ENDPOINT=http://minio:9000

# ── Cloudflare Tunnel ──
# Create a tunnel in the Zero Trust dashboard, route app.glacianav.com to
# http://web:3000, and paste the tunnel token here.
TUNNEL_TOKEN=

# ── Deployment overrides (optional) ──
# WEB_IMAGE=ghcr.io/nimaema/glacianav_webapp:latest
# WATCHTOWER_INTERVAL=60
# DOCKER_API_VERSION=1.40
