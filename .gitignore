# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example
!.env.example

# vercel
.vercel

# supabase CLI local cache (linked-project ref etc.) — not local dev
# scaffold (no `supabase init` used), just machine-local CLI state
/supabase/.temp

# real internal data pulled from the Notes/CRM apps for the one-time
# migration (src/db/migrate-real-data.ts) — recordings, transcripts,
# real team/customer info. Never commit; script docs how it was extracted.
/src/db/migration-data

# typescript
*.tsbuildinfo
next-env.d.ts
