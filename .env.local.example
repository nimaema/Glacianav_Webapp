# Copy to .env.local and fill in from your Supabase project's
# Settings → API and Settings → Database pages.

# Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Settings → API → Project API keys → service_role (server-only, never
# expose to the browser — used for admin-provisioning scripts, not app code)
SUPABASE_SERVICE_ROLE_KEY=

# Settings → Database → Connection string → URI, "Transaction pooler"
# (port 6543). Used by src/db/client.ts at runtime.
DATABASE_URL=

# Settings → Database → Connection string → URI, "Session pooler" or
# direct (port 5432). Used by drizzle-kit for migrations — the transaction
# pooler above doesn't support the DDL commands migrations need.
DIRECT_URL=

# The app's own public origin — used server-side by the OAuth callback
# route to build its post-sign-in redirect, since request.url can't be
# trusted for this behind a reverse proxy/tunnel (resolves to the
# container's internal bind address instead of the real domain). No
# trailing slash. Production: https://app.glacianav.com
SITE_URL=http://localhost:3400

# Set to "true" once Microsoft SSO is configured in Supabase's dashboard
# (Authentication → Providers → Azure) AND a real sign-in has been verified
# end-to-end. Until then, leave unset — middleware.ts won't redirect
# unauthenticated requests to /login, so there's no lockout risk while SSO
# is still being set up. See src/app/login/page.tsx.
AUTH_REQUIRED=

# Nova (workspace assistant, src/lib/ai/nova-agent.ts) and the real
# transcription pipeline (src/lib/ai/transcribe.ts + analyze-transcript.ts)
# both run on DeepSeek — same account/keys as glacianav-notes, which
# already runs these in production. Leave DEEPSEEK_API_KEY unset (or "dev")
# to fall back to a small built-in mock so the UI is still exercisable
# without a real key.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Local `npm run dev` queues isolated Python work here. Start the worker with
# `./scripts/setup_nova_sandbox.sh` before asking Nova to run Python.
NOVA_JOBS_DIR=.nova-jobs
NOVA_CONFIRMATION_SECRET=
# Required by the production orchestrator. For local testing, pass this same
# value when calling POST /api/internal/nova/process.
NOVA_INTERNAL_SECRET=
# Background queue lanes. Three keeps short answers moving while a file renders.
NOVA_PROCESSOR_CONCURRENCY=3
# Maximum wait for one DeepSeek round trip before the durable job retries.
DEEPSEEK_TIMEOUT_MS=45000

# Real speech-to-text for Record. Leave unset (or "dev") to fall back to a
# short canned mock transcript.
ASSEMBLYAI_API_KEY=

# MinIO (S3-compatible) — where recorded audio actually gets stored.
# docker-compose.yml already provisions the minio service + "audio" bucket
# in production; for local dev, run a throwaway MinIO container and point
# these at it (see src/lib/storage.ts).
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=audio
