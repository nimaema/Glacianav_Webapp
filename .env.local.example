# Copy to .env.local and fill in from your Supabase project's
# Settings → API and Settings → Database pages.

# Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Settings → API → Project API keys → service_role (server-only, never
# expose to the browser — used for admin-provisioning scripts, not app code)
SUPABASE_SERVICE_ROLE_KEY=

# Settings → Database → Connection string → URI, "Transaction pooler"
# (port 6543). Used by src/db/client.ts at runtime.
DATABASE_URL=

# Settings → Database → Connection string → URI, "Session pooler" or
# direct (port 5432). Used by drizzle-kit for migrations — the transaction
# pooler above doesn't support the DDL commands migrations need.
DIRECT_URL=

# The app's own public origin — used server-side by the OAuth callback
# route to build its post-sign-in redirect, since request.url can't be
# trusted for this behind a reverse proxy/tunnel (resolves to the
# container's internal bind address instead of the real domain). No
# trailing slash. Production: https://app.glacianav.com
SITE_URL=http://localhost:3400

# Set to "true" once Microsoft SSO is configured in Supabase's dashboard
# (Authentication → Providers → Azure) AND a real sign-in has been verified
# end-to-end. Until then, leave unset — middleware.ts won't redirect
# unauthenticated requests to /login, so there's no lockout risk while SSO
# is still being set up. See src/app/login/page.tsx.
AUTH_REQUIRED=
